@prefix skos: <http://www.w3.org/2004/02/skos/core#>.

<https://data.vlaanderen.be/id/conceptscheme/VKBO/Onderneming> a skos:ConceptScheme;
    skos:prefLabel "Codelijsten Implementatiemodel VKBO Onderneming"@nl;
    skos:definition "Codelijsten toegepast in de implementatie van Onderneming bij VKBO volgens het Implementatiemodel VKBO Onderneming."@nl;
