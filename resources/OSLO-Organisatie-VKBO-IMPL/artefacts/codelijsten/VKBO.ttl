    skos:topConceptOf <https://data.vlaanderen.be/id/conceptscheme/VKBO>;
    skos:notation "VKBO-Onderneming".
<https://data.vlaanderen.be/id/conceptscheme/VKBO> a skos:ConceptScheme;
    skos:prefLabel "VKBO codelijsten"@nl;
    skos:definition "Alle codelijsten die specifiek zijn voor VKBO."@nl;
    skos:notation "VKBO".
