@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.

<https://data.vlaanderen.be/id/conceptscheme/Doorhalingstype/v1> a skos:ConceptScheme;
    skos:prefLabel "Codelijst soorten doorhalingen (v1)"@nl;
    skos:definition "Codelijst soorten doorhalingen die toegepast kunnen worden op ondernemingen en vestigingen."@nl;
    skos:inScheme <https://data.vlaanderen.be/id/conceptscheme/Doorhalingstype>;
    skos:topConceptOf <https://data.vlaanderen.be/id/conceptscheme/Doorhalingstype>;
    skos:notation "Doorhalingstype-v1".
<https://data.vlaanderen.be/id/conceptscheme/Doorhalingstype> a skos:ConceptScheme;
    skos:prefLabel "Codelijst soorten doorhalingen"@nl;
    skos:definition "Codelijst soorten doorhalingen die toegepast kunnen worden op ondernemingen en vestigingen."@nl;
    skos:notation "Doorhalingstype".
<https://data.vlaanderen.be/id/concept/Doorhalingstype/v1/Adres> a skos:Concept;
    skos:prefLabel "Ambstbehalve doorhaling adres"@nl;
    skos:definition "Het adres is ambstbehalve doorgehaald."@nl;
    skos:inScheme <https://data.vlaanderen.be/id/conceptscheme/Doorhalingstype/v1>;
    skos:topConceptOf <https://data.vlaanderen.be/id/conceptscheme/Doorhalingstype/v1>;
    skos:notation "Adres".
<https://data.vlaanderen.be/id/concept/Doorhalingstype/v1/Onderneming> a skos:Concept;
    skos:prefLabel "Ambstbehalve doorhaling onderneming"@nl;
    skos:definition "De onderneming is ambstbehalve doorgehaald."@nl;
    skos:inScheme <https://data.vlaanderen.be/id/conceptscheme/Doorhalingstype/v1>;
    skos:topConceptOf <https://data.vlaanderen.be/id/conceptscheme/Doorhalingstype/v1>;
    skos:notation "Onderneming".
