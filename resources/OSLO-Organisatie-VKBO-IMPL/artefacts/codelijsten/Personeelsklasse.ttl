<https://data.vlaanderen.be/id/conceptscheme/RSZ-Personeelsklasse/v1> a skos:ConceptScheme;
    skos:prefLabel "Codelijst RSZ personeelsklassen (v1)"@nl;
    skos:definition "Codelijst van personeelklassen gebruikt door RSZ om de omvang van een onderneming aan te duiden."@nl;
    skos:inScheme <https://data.vlaanderen.be/id/conceptscheme/RSZ-Personeelsklasse>;
    skos:topConceptOf <https://data.vlaanderen.be/id/conceptscheme/RSZ-Personeelsklasse>;
    skos:notation "RSZ-Personeelklasse-v1".
<https://data.vlaanderen.be/id/conceptscheme/RSZ-Personeelsklasse> a skos:ConceptScheme;
    skos:prefLabel "Codelijst RSZ personeelsklassen"@nl;
    skos:definition "Codelijst van personeelklassen gebruikt door RSZ om de omvang van een onderneming aan te duiden."@nl;
