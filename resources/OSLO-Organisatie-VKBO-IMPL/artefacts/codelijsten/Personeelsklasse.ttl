    skos:prefLabel "RSZ Personeelsklasse 1"@nl;
    skos:definition "De grootte van de onderneming bedraagt 1 tot en met 4 personeelsleden."@nl;
    skos:inScheme <https://data.vlaanderen.be/id/conceptscheme/RSZ-Personeelsklasse/v1>;
    skos:topConceptOf <https://data.vlaanderen.be/id/conceptscheme/RSZ-Personeelsklasse/v1>;
    skos:notation "1".
