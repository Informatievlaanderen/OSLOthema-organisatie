<https://data.vlaanderen.be/id/conceptscheme/RSZ-Personeelsklasse/v1/0> a skos:Concept;
    skos:prefLabel "RSZ Personeelsklasse 0"@nl;
    skos:definition "De onderneming heeft geen personeelsleden in dienst, de grootte bedraagt 0 personeelsleden."@nl;
    skos:inScheme <https://data.vlaanderen.be/id/conceptscheme/RSZ-Personeelsklasse/v1>;
    skos:topConceptOf <https://data.vlaanderen.be/id/conceptscheme/RSZ-Personeelsklasse/v1>;
